<Window x:Class="xpaste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:xpaste.Converters"
        Title="xpaste" Height="600" Width="620" MinWidth="500" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource MaterialDesignPaper}"
        Foreground="{DynamicResource MaterialDesignBody}"
        md:ThemeAssist.Theme="Inherit"
        Closing="OnClosing">

    <Window.Resources>
        <conv:SlotDisplayConverter x:Key="SlotConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#009688" Padding="20,14">
            <Grid>
                <!-- Back button + title (edit mode) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding CancelEditCommand}"
                            Foreground="White" Padding="4" Margin="0,0,4,0"
                            ToolTip="Back">
                        <md:PackIcon Kind="ArrowLeft" Width="20" Height="20"/>
                    </Button>
                    <TextBlock Text="{Binding EditTitle}" FontSize="20" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- App title (list mode) -->
                <TextBlock Text="xpaste" FontSize="20" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"
                           Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}"/>

                <!-- Auto-start toggle + info button (always) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ToggleButton IsChecked="{Binding AutoStart}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Foreground="White" Margin="0,0,8,0"/>
                    <TextBlock Text="Auto-start" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Foreground="White" Padding="4"
                            Command="{Binding ToggleInfoCommand}"
                            ToolTip="Keyboard shortcuts &amp; help">
                        <md:PackIcon Kind="InformationOutline" Width="20" Height="20"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ LIST PANEL ═══ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}">
            <ItemsControl ItemsSource="{Binding Snippets}" Margin="16,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <md:Card Margin="0,5" Padding="14,10" md:ElevationAssist.Elevation="Dp2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#009688"
                                        CornerRadius="4" Padding="7,3" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Slot, Converter={StaticResource SlotConv}}"
                                               FontSize="11" Foreground="White"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="14"
                                           Foreground="{DynamicResource MaterialDesignBody}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="2"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        Command="{Binding DataContext.EditSnippetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Foreground="{DynamicResource MaterialDesignBody}"
                                        ToolTip="Edit">
                                    <md:PackIcon Kind="Pencil" Width="16" Height="16"/>
                                </Button>
                                <Button Grid.Column="3"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        Command="{Binding DataContext.DeleteSnippetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Foreground="#EF5350"
                                        ToolTip="Delete">
                                    <md:PackIcon Kind="Delete" Width="16" Height="16"/>
                                </Button>
                            </Grid>
                        </md:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ═══ EDIT PANEL ═══ -->
        <ScrollViewer Grid.Row="1"
                      Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20">
                <TextBox md:HintAssist.Hint="Snippet name (e.g. Work Password)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="{DynamicResource MaterialDesignBody}"
                         Margin="0,0,0,16"/>

                <TextBox md:HintAssist.Hint="Snippet content (text or password)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="{DynamicResource MaterialDesignBody}"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="90"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,16"/>

                <ComboBox md:HintAssist.Hint="Hotkey slot"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          ItemsSource="{Binding SlotOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding EditSlot}"
                          Foreground="{DynamicResource MaterialDesignBody}"
                          Margin="0,0,0,8"/>

                <TextBlock Text="{Binding EditError}" Foreground="#EF5350"
                           Margin="0,4,0,16"
                           Visibility="{Binding EditError, Converter={StaticResource BoolToVis}}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="CANCEL"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{DynamicResource MaterialDesignBody}"
                            Command="{Binding CancelEditCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="SAVE"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding SaveEditCommand}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ ADD BUTTON ROW ═══ -->
        <Border Grid.Row="2" Padding="16,8,16,8"
                Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}">
            <Button HorizontalAlignment="Right"
                    Style="{StaticResource MaterialDesignFloatingActionButton}"
                    Command="{Binding AddSnippetCommand}"
                    ToolTip="Add snippet">
                <md:PackIcon Kind="Plus" Width="24" Height="24"/>
            </Button>
        </Border>

        <!-- ═══ FOOTER ═══ -->
        <Border Grid.Row="3" Background="{DynamicResource MaterialDesignDivider}" Padding="16,8">
            <TextBlock Text="Ctrl+Shift+1–0  type snippet  •  Ctrl+Shift++  open  •  Ctrl+Shift+-  minimize"
                       FontSize="11" Foreground="{DynamicResource MaterialDesignBody}"
                       Opacity="0.6" HorizontalAlignment="Center"/>
        </Border>

        <!-- ═══ DELETE CONFIRM OVERLAY ═══ -->
        <Grid Grid.Row="0" Grid.RowSpan="4"
              Visibility="{Binding IsConfirmingDelete, Converter={StaticResource BoolToVis}}">
            <!-- dim backdrop -->
            <Rectangle Fill="Black" Opacity="0.55"/>
            <!-- confirmation card -->
            <md:Card HorizontalAlignment="Center" VerticalAlignment="Center"
                     Padding="32,28" md:ElevationAssist.Elevation="Dp8"
                     MinWidth="300">
                <StackPanel>
                    <TextBlock FontSize="15" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{DynamicResource MaterialDesignBody}">
                        <Run Text="Delete "/>
                        <Run Text="&quot;"/><Run Text="{Binding PendingDeleteName}"/><Run Text="&quot;"/>
                        <Run Text="?"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="CANCEL" Margin="0,0,12,0"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Command="{Binding CancelDeleteCommand}"/>
                        <Button Content="DELETE"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#EF5350" BorderBrush="#EF5350" Foreground="White"
                                Command="{Binding ConfirmDeleteCommand}"/>
                    </StackPanel>
                </StackPanel>
            </md:Card>
        </Grid>
        <!-- ═══ INFO OVERLAY ═══ -->
        <Grid Grid.Row="0" Grid.RowSpan="4"
              Visibility="{Binding IsShowingInfo, Converter={StaticResource BoolToVis}}">
            <Rectangle Fill="Black" Opacity="0.55"/>
            <md:Card HorizontalAlignment="Center" VerticalAlignment="Center"
                     Padding="32,28" md:ElevationAssist.Elevation="Dp8"
                     MinWidth="360" Background="#2D2D2D">
                <StackPanel>
                    <TextBlock Text="How to use xpaste" FontSize="16" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="All hotkeys require Ctrl+Shift" FontSize="11"
                               Foreground="#AAAAAA"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <!-- Hotkeys section -->
                    <TextBlock Text="HOTKEYS" FontSize="10" FontWeight="Bold"
                               Foreground="#888888" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+Shift+1 through 0" FontFamily="Consolas" FontSize="12" Foreground="#4DB6AC" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Type snippet into any focused window" Foreground="White" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+Shift++" FontFamily="Consolas" FontSize="12" Foreground="#4DB6AC" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Open / close this window" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl+Shift+–" FontFamily="Consolas" FontSize="12" Foreground="#4DB6AC" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="Minimize to tray" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Tray section -->
                    <TextBlock Text="TRAY" FontSize="10" FontWeight="Bold"
                               Foreground="#888888" Margin="0,16,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Left-click" FontFamily="Consolas" FontSize="12" Foreground="#4DB6AC" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Open this window" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Right-click" FontFamily="Consolas" FontSize="12" Foreground="#4DB6AC" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Change password, auto-start, view log, exit" Foreground="White" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="RDP windows" FontFamily="Consolas" FontSize="12" Foreground="#4DB6AC" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="Auto-detected — uses clipboard for reliable paste into remote sessions" Foreground="White" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </Grid>

                    <Button Content="CLOSE" HorizontalAlignment="Center" Margin="0,24,0,0"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding ToggleInfoCommand}"/>
                </StackPanel>
            </md:Card>
        </Grid>
    </Grid>
</Window>
