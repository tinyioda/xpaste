<Window x:Class="xpaste.Views.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="xpaste — Change Master Password" Height="400" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        Foreground="{DynamicResource MaterialDesignBody}"
        md:ThemeAssist.Theme="Inherit">
    <Grid Margin="40,32,40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="xpaste" FontSize="30" FontWeight="Bold"
                   Foreground="White" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Text="Change master password"
                   HorizontalAlignment="Center" Margin="0,6,0,0"
                   Foreground="{DynamicResource MaterialDesignBody}" Opacity="0.7"/>

        <!-- spacer row 2 -->

        <PasswordBox Grid.Row="3" x:Name="CurrentPasswordBox"
                     md:HintAssist.Hint="Current password"
                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                     KeyDown="PasswordBox_KeyDown"/>

        <!-- spacer row 4 -->

        <PasswordBox Grid.Row="5" x:Name="NewPasswordBox"
                     md:HintAssist.Hint="New password"
                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                     KeyDown="PasswordBox_KeyDown"/>

        <!-- spacer row 6 -->

        <PasswordBox Grid.Row="7" x:Name="ConfirmPasswordBox"
                     md:HintAssist.Hint="Confirm new password"
                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                     KeyDown="PasswordBox_KeyDown"/>

        <TextBlock Grid.Row="8" x:Name="ErrorText" Text=""
                   Foreground="#EF5350"
                   HorizontalAlignment="Center" Margin="0,8,0,0"/>

        <!-- spacer row 9 -->

        <Button Grid.Row="10" Content="CHANGE PASSWORD"
                HorizontalAlignment="Stretch"
                Style="{StaticResource MaterialDesignRaisedButton}"
                Click="OnChange"/>
    </Grid>
</Window>
