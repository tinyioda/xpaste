<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>xpaste.ico</ApplicationIcon>
    <!-- Default publish target: self-contained single-file Windows x64 exe -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishProfile>win-x64</PublishProfile>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="xpaste.ico"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageReference Include="H.NotifyIcon.Wpf" Version="2.4.1" />
    <PackageReference Include="MaterialDesignThemes" Version="5.3.2" />
  </ItemGroup>

</Project>
