<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile: produces a single self-contained .exe for Windows x64.
  Users do not need .NET installed.

  Usage:
    dotnet publish -p:PublishProfile=win-x64
  or simply:
    dotnet publish
  (win-x64 is set as the default RuntimeIdentifier in the csproj)
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <!-- Bundle native WPF/WinForms libs into the single file instead of extracting temp files -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <!-- Compress embedded assemblies to reduce output size (~30-40% smaller) -->
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- Strip debug symbols from the output -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <PublishDir>publish\</PublishDir>
  </PropertyGroup>
</Project>
